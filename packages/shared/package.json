{
  "name": "@starter-kit/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "require": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    },
    "./auth/*": {
      "types": "./dist/auth/*.d.ts",
      "require": "./dist/auth/*.js",
      "default": "./dist/auth/*.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "require": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    },
    "./db/*": {
      "types": "./dist/db/*.d.ts",
      "require": "./dist/db/*.js",
      "default": "./dist/db/*.js"
    },
    "./queue": {
      "types": "./dist/queue/index.d.ts",
      "require": "./dist/queue/index.js",
      "default": "./dist/queue/index.js"
    },
    "./queue/*": {
      "types": "./dist/queue/*.d.ts",
      "require": "./dist/queue/*.js",
      "default": "./dist/queue/*.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "require": "./dist/ai/index.js",
      "default": "./dist/ai/index.js"
    },
    "./ai/*": {
      "types": "./dist/ai/*.d.ts",
      "require": "./dist/ai/*.js",
      "default": "./dist/ai/*.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" \"auth/**/*.ts\" \"db/**/*.ts\" \"queue/**/*.ts\" \"ai/**/*.ts\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.67.0",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
